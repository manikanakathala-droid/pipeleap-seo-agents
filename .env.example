# ── Google Search Console ────────────────────────────────────────────────────
# Path to service account JSON file (for local runs)
GSC_CREDENTIALS_FILE=credentials/gsc_service_account.json
# Or pass the full JSON as a string (used in CI/CD via GitHub Actions secret)
# GSC_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── DataForSEO (keyword volume, SERPs, backlink data) ───────────────────────
DATAFORSEO_LOGIN=your_dataforseo_login
DATAFORSEO_PASSWORD=your_dataforseo_password

# ── Google PageSpeed Insights ────────────────────────────────────────────────
PAGESPEED_API_KEY=your_pagespeed_api_key

# ── Ahrefs API ───────────────────────────────────────────────────────────────
AHREFS_API_KEY=your_ahrefs_api_key

# ── CMS / Launchpad repo path override ──────────────────────────────────────
# Override the default sibling-directory discovery for the launchpad repo
# PIPELEAP_LAUNCHPAD_DIR=/absolute/path/to/pipeleap-launchpad

# ── GitHub (for CI/CD publishing to launchpad + API backlink campaigns) ─────
GITHUB_TOKEN=your_github_personal_access_token

# ── Backlink platform API keys (all optional) ───────────────────────────────
DEVTO_API_KEY=your_devto_api_key
HASHNODE_TOKEN=your_hashnode_token
MEDIUM_INTEGRATION_TOKEN=your_medium_token

# ── Observability ────────────────────────────────────────────────────────────
POSTHOG_API_KEY=your_posthog_api_key
SENTRY_DSN=your_sentry_dsn

# ── CI/CD-only secrets (set in GitHub Actions, not needed locally) ───────────
# LAUNCHPAD_DEPLOY_TOKEN=github_deploy_token_for_launchpad_repo
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
